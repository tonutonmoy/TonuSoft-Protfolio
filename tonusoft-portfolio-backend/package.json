{
  "name": "fastify-server",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "pg": "npx prisma generate",
    "pm": "npx prisma migrate dev",
    "lint:check": "eslint . --ext .ts",
    "lint:fix": "eslint . --fix",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@aws-sdk/lib-storage": "^3.717.0",
    "@fastify/cors": "^8.2.0",
    "@fastify/jwt": "^6.4.1",
    "@fastify/multipart": "^7.7.3",
    "@fastify/static": "^6.12.0",
    "@fastify/swagger": "^8.8.0",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.25.2",
    "fastify-multer": "^2.0.3",
    "fastify-plugin": "^4.5.1",
    "http-status": "^1.7.4",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "nodemailer": "^6.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^6.4.17",
    "eslint": "^9.15.0",
    "prettier": "^3.4.1",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}
