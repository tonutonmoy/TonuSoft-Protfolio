// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                      String      @id @default(auto()) @map("_id") @db.ObjectId
  firstName               String
  lastName                String
  email                   String      @unique
  password                String
  role                    UserRoleEnum @default(USER)
  status                  UserStatus   @default(ACTIVE)
  image                   String[]
  otp                     String?
  otpExpiry               DateTime?

  isEmailVerified         Boolean     @default(true)
  emailVerificationToken  String?
  emailVerificationTokenExpires DateTime?

  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt


  @@map("users")
}

model BlogPost {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  slug       String   @unique
  author     String?
  excerpt    String?
  content    String
  coverUrl   String?  @map("cover_url")
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("blog_posts")
}

model Career {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  department  String?
  location    String?
  type        String?
  description String?
  isOpen      Boolean  @default(true) @map("is_open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("careers")
}

model Product {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  tagline    String?
  description String?
  category   String?  @db.ObjectId
  productType ProductType @default(COMPANY)
  imageUrl   String?  @map("image_url")
  linkUrl    String?  @map("link_url")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  categoryRef Category? @relation(fields: [category], references: [id])

  @@map("products")
}

model Category {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String   @unique
  description String?
  products   Product[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("categories")
}

model Service {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  icon       String?
  description String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("services")
}

model Project {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  category   String?
  description String?
  imageUrl   String?  @map("image_url")
  linkUrl    String?  @map("link_url")
  featured   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("projects")
}

model Skill {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  technology  String
  level       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("skills")
}

model Pricing {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  price       String?
  description String?
  features    String[]
  popular     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("pricing")
}

model JobApplication {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  careerId    String
  name        String
  email       String
  resumeUrl   String?  @map("resume_url")
  coverLetter String?  @map("cover_letter")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("job_applications")
}

enum UserRoleEnum {
  USER
  ADMIN
  SUPERADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum ProductType {
  DEMO
  COMPANY
}